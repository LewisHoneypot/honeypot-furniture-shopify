<script>
  (function () {
    const allowedCategories = [
      'sofas',
      'corner-sofas',
      'sofa-beds',
      'u-shape-sofas',
      '4-seater-sofas',
      '3-seater-sofas',
      '2-seater-sofas',
      'modular-sofas',
      'recliner-sofas',
      'armchairs',
      'foot-stools',
      'beige',
      'grey',
      'black-sofas',
      'blue-sofas',
      'brown-sofas',
      'green-sofas',
      'carnaby-range',
      'bishop-range',
      'inga-range',
      'cimiano-range',
      'new-in',
      'naples',
      'azzuro',
      'rupert-sofas',
      'jacob-range'
    ];

    const currentCollectionSlug = window.location.pathname
      .replace('/collections/', '')
      .split('/')[0];

    if (!allowedCategories.includes(currentCollectionSlug)) return;

    const processedHandles = new Set();

    async function createWidget(item) {
      try {
        // ✅ Prevent duplicates
        if (item.dataset.lsProcessed === 'true') return;
        if (item.querySelector('.lipscore-rating-small')) return;

        const link = item.querySelector('a[href*="/products/"]');
        if (!link) return;

        const href = link.getAttribute('href');
        const handle = href.split('/products/')[1]?.split('?')[0];
        if (!handle || processedHandles.has(handle)) return;

        processedHandles.add(handle);

        const res = await fetch(`/products/${handle}.js`);
        if (!res.ok) return;

        const data = await res.json();

        const widget = document.createElement('div');
        widget.className = 'lipscore-rating-small';

        widget.dataset.lsProductName = data.title;
        widget.dataset.lsBrand = data.vendor;
        widget.dataset.lsSku = data.variants.map(v => v.sku).join(';');
        widget.dataset.lsProductId = data.id;
        widget.dataset.lsProductUrl = window.location.origin + data.url;
        widget.dataset.lsImageUrl = data.featured_image?.startsWith('http')
          ? data.featured_image
          : 'https:' + data.featured_image;
        widget.dataset.lsPrice = (data.price / 100).toFixed(2);
        widget.dataset.lsPriceCurrency = window.Shopify?.currency?.active || 'GBP';
        widget.dataset.lsAvailability = data.available ? '1' : '0';

        const dimensions = item.querySelector('.collection-dimensions');
        const info = item.querySelector('.card__information');

        if (dimensions) {
          dimensions.insertAdjacentElement('beforebegin', widget);
        } else if (info) {
          info.appendChild(widget);
        }

        item.dataset.lsProcessed = 'true';

        if (typeof lipscore !== 'undefined') {
          lipscore.initWidgets();
        }
      } catch (err) {
        console.warn('Lipscore error:', err);
      }
    }

    function scanProducts() {
      const items = document.querySelectorAll('#product-grid .grid__item');
      items.forEach(item => createWidget(item));
    }

    // ✅ Initial run
    document.addEventListener('DOMContentLoaded', scanProducts);

    // ✅ Observe dynamic loads (filters, pagination, infinite scroll)
    const grid = document.querySelector('#product-grid');
    if (!grid) return;

    const observer = new MutationObserver(() => {
      scanProducts();
    });

    observer.observe(grid, {
      childList: true,
      subtree: true
    });

    // ✅ Logo replacement fix (cleaned + safe)
    window.addEventListener('load', function () {
      setInterval(() => {
        const logoGroup = document.querySelector('g.lipscore-service-review-logo');

        if (logoGroup && logoGroup.parentNode && !document.querySelector('.lipscore-service-review-logo-image')) {
          const svgNS = 'http://www.w3.org/2000/svg';
          const image = document.createElementNS(svgNS, 'image');

          image.setAttributeNS(null, 'href', 'https://cdn.shopify.com/s/files/1/0857/1358/4415/files/LS_WHITE_LOGO.png?v=1751357279');
          image.setAttributeNS(null, 'width', '300');
          image.setAttributeNS(null, 'height', '100');
          image.setAttributeNS(null, 'class', 'lipscore-service-review-logo-image');

          logoGroup.parentNode.replaceChild(image, logoGroup);
        }
      }, 3000);
    });
  })();
</script>

<style>
  .lipscore-rating {
    float: inline-end;
  }

  .lipscore-testimonial {
    margin: 20px 0;
  }

  .lipscore-rating-review-link {
    color: black;
  }

  .lipscore-product-widgets {
    max-width: 1200px;
    padding: 20px;
    margin: 0 auto;
  }

  .lipscore-rating-small {
    display: block;
    /* min-height: 27px; */
  }

  .lipscore-service-review-badge-small-short text,
  .lipscore-service-review-badge-small-short .lipscore-rating-star > g {
    fill: #fff !important;
  }

  .lipscore-service-review-badge-small-short
    svg.lipscore-rating-star.lipscore-star-incomplete.lipscore-svg-rating-star
    > g.lipscore-star-last-half {
    fill: #d1d1d1 !important;
  }

  .lipscore-service-review-badge-small-short .lipscore-service-review-logo {
    display: none;
  }
</style>
