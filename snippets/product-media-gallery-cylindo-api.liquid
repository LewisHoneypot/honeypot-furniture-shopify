{% assign customer_id = '6981' %}
{% assign product_code = product.metafields.custom.cylindo_parent | upcase | default: 'LAVENDER-SOFA-3-SEATER' %}
{% assign upholstery_colour = product.metafields.Details.Colour | upcase %}
{% assign frame_count = 32 %}

<div id="pdp-gallery" style="max-width:820px;margin:0 auto;">
  <!-- Main display -->
  <div
    id="main-image-wrapper"
    style="aspect-ratio:3/3.4;position:relative;touch-action:none;user-select:none;-webkit-user-drag:none;cursor:grab;"
  >
    <img
      id="main-image"
      src="https://content.cylindo.com/api/v2/{{ customer_id }}/products/{{ product_code }}/frames/1/{{ product_code }}.webp?size=768&feature=UPHOLSTERY:{{ upholstery_colour }}"
      alt="{{ product.title }} 360 view"
      style="width:100%;height:100%;object-fit:cover;pointer-events:none;"
      draggable="false"
      height="400"
      width="400"
    >
  </div>

  <!-- Thumbnails -->
  <div id="thumb-bar" style="display:flex;gap:8px;overflow-x:auto;margin-top:1rem;align-items:center;">
    <div class="cylindo-thumbnail-btn active">
      <div class="thumb-inner">
        <img
          class="thumb"
          data-type="cylindo"
          data-frame="1"
          src="https://content.cylindo.com/api/v2/{{ customer_id }}/products/{{ product_code }}/frames/1/{{ product_code }}.webp?size=768&feature=UPHOLSTERY:{{ upholstery_colour }}"
          alt="{{ product.title }} 360"
          draggable="false"
          height="48"
          width="48"
        >
      </div>
    </div>
    {% for media in product.media %}
      {% unless media.id == product.selected_or_first_available_variant.featured_media.id %}
        <div class="cylindo-thumbnail-btn">
          <div class="thumb-inner">
            <img
              class="thumb"
              data-type="shopify"
              data-src="{{ media | image_url: width: 1500 }}"
              src="{{ media | image_url: width: 150 }}"
              alt="{{ media.alt | escape }}"
              draggable="false"
              height="48"
              width="48"
            >
          </div>
        </div>
      {% endunless %}
    {% endfor %}
  </div>
</div>

<style>
  #thumb-bar {
    display: flex;
    gap: 8px;
    overflow-x: auto;
    align-items: center;
  }

  .cylindo-thumbnail-btn {
    width: 74px;
    height: 58px;
    flex-shrink: 0;
    border-radius: 4px;
    border: 1px solid #ccc;
    padding: 4px; /* visible padding */
    box-sizing: border-box;
    background-color: #ededed;
  }

  .thumb-inner {
    width: 100%;
    height: 100%;
    overflow: hidden; /* crop excess */
    border-radius: 2px; /* optional: soften inside corners */
  }

  .thumb-inner img.thumb {
    width: 100%;
    height: 100%;
    object-fit: cover; /* crop if aspect ratio doesn't match */
    display: block;
  }

  .cylindo-thumbnail-btn.active {
    border: 1px solid #435d6d !important; /* highlight active */
  }

  #thumb-bar::-webkit-scrollbar {
    display: none;
  }
</style>

<!-- Load external JS -->
<script src="{{ 'cylindo-360.js' | asset_url }}" defer></script>

<!-- Pass configuration to the script -->
<script>
  window.cylindoConfig = {
    customerId: "{{ customer_id }}",
    productCode: "{{ product_code }}",
    upholstery: "{{ upholstery_colour }}",
    frameCount: {{ frame_count }},
    startFrame: 1
  };
</script>
