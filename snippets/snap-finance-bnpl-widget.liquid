<div id="snap-uk-widgets-product-bnpl" style="padding-bottom:10px;min-height:63px; margin-top:4px"></div>

{% assign product_price = product.price | money_without_currency %}

<script>
document.addEventListener('DOMContentLoaded', function() {
    var productPrice = +{{ product_price | replace: "£", "" | replace: ",", "" | split: " " | first }};
    if (productPrice >= 250) {
        snapuk.init("fq0hLCzt4Qj1V15ZK78VvjO9K7GUA9zW");
        snapuk.widgets.productBNPL({
            merchantId: 4816,
            costOfGoods: productPrice,
            theme: "LIGHT",
        });

        // Wait for the widget to be initialized and then replace the "Learn more" text with a chevron
        setTimeout(function() {
            // Select the shadow host element
            const shadowHost = document.querySelector('#snap-uk-widgets-product-bnpl');

            if (shadowHost) {
                // Access the shadow root
                const shadowRoot = shadowHost.shadowRoot;

                if (shadowRoot) {
                    // Find the "Learn more" element
                    const learnMoreElement = shadowRoot.querySelector('#rbp-bnpl-learn-more');

                    if (learnMoreElement) {
                        // Replace the "Learn more" text with a chevron icon
                        learnMoreElement.innerHTML = `
                          <svg aria-hidden="true" focusable="false" role="presentation" class="icon icon-caret" viewBox="0 0 10 6">
                            <path fill-rule="evenodd" clip-rule="evenodd" d="M9.354.646a.5.5 0 00-.708 0L5 4.293 1.354.646a.5.5 0 00-.708.708l4 4a.5.5 0 00.708 0l4-4a.5.5 0 000-.708z" fill="rgba(var(--color-foreground),.8)"></path>
                          </svg>
                        `;

                        // Add click event listener to the parent element to simulate a click on the chevron
                        shadowHost.addEventListener('click', function() {
                            // Find the chevron element
                            const chevronElement = shadowRoot.querySelector('#rbp-bnpl-learn-more');
                            if (chevronElement) {
                                // Simulate a click on the chevron
                                chevronElement.click();
                            }
                        });
                    }
                }
            }
        }, 1000); // Adjust the timeout duration if necessary

    } else {
        var messageElement = document.createElement('div');
        messageElement.textContent = "";
        messageElement.style.textAlign = 'center';
        messageElement.style.marginTop = '10px';

        var widgetContainer = document.getElementById('snap-uk-widgets-product-bnpl');
        widgetContainer.appendChild(messageElement);
    }
});

// Wait until the DOM is fully loaded
document.addEventListener('DOMContentLoaded', function() {
  var productPrice = +{{ product_price | replace: "£", "" | replace: ",", "" | split: " " | first }};
  if (productPrice >= 250) {

    // Select the shadow host element
    const shadowHost = document.querySelector('#snap-uk-widgets-product-bnpl');
    
    // Access the shadow root
    const shadowRoot = shadowHost.shadowRoot;
    
    // Create a style element
    const style = document.createElement('style');
    
    // Add CSS rules to the style element
    style.textContent = `
      .injected-product-widget {
        background-color: #fff !important;
        border: 0.1rem solid rgba(var(--color-foreground),.8) !important;
        border-radius: 0 !important;
        min-height:58px !important;
        min-width: 100%;
        padding: 0 !important;
        cursor: pointer;
      }
      .injected-product-widget .injected-product-widget__grid__text p {
        align-items: center !important;
        font-size: clamp(11px, 3.5cqw, 14px) !important;
        gap: 0 !important;
      }
      .icon-caret {
        width: 1.6rem !important;
        height: 1.6rem !important;
        transform: rotate(-90deg);
      }
    `;
    
    // Append the style element to the shadow root
    shadowRoot.appendChild(style);
  };
});
</script>
