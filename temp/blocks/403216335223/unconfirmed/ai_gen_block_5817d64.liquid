{% doc %}
  @prompt
    Build a responsive content block for a garden firepit product. The block should:

📱 Responsiveness:
Desktop layout:

Full-width section.

A large background image on the left side (firepit lifestyle image).

Overlay heading text on the top-left of the image.

On the right side, stack 3 vertically-aligned feature images, each inside a container with:

A border or background colour (customisable).

A caption/text section underneath (customisable).

Mobile layout:

Stack all elements vertically.

Heading text appears at the top of the block.

Main lifestyle image below it.

Then display the 3 feature images each with:

Their border/background and text section underneath.

🎨 Customization:
Section background colour should be editable.

Border/background of each feature image block should be editable independently.

Fonts and font sizes should adapt for mobile and desktop (e.g., scalable heading).

🧩 Content slots:
One slot for main lifestyle image.

One slot for heading text.

Three slots for feature images.

Three corresponding slots for text below each image.

{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .firepit-block-{{ ai_gen_id }} {
    background-color: {{ block.settings.background_color }};
    padding: 0;
    overflow: hidden;
  }

  .firepit-container-{{ ai_gen_id }} {
    display: flex;
    flex-direction: row;
    width: 100%;
  }

  .firepit-main-image-container-{{ ai_gen_id }} {
    position: relative;
    width: 60%;
    overflow: hidden;
  }

  .firepit-main-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .firepit-main-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    min-height: 600px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
  }

  .firepit-main-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 400px;
    max-height: 400px;
  }

  .firepit-heading-{{ ai_gen_id }} {
    position: absolute;
    top: 40px;
    left: 40px;
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    max-width: 80%;
    margin: 0;
    text-shadow: 0 2px 4px rgba(0, 0, 0, 0.2);
    z-index: 2;
  }

  .firepit-features-container-{{ ai_gen_id }} {
    width: 40%;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 40px;
    gap: 20px;
  }

  .firepit-feature-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    height: calc(33.333% - 14px);
  }

  .firepit-feature-image-container-{{ ai_gen_id }} {
    width: 100%;
    height: 0;
    padding-bottom: 75%;
    position: relative;
    overflow: hidden;
  }

  .firepit-feature-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    position: absolute;
    top: 0;
    left: 0;
  }

  .firepit-feature-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    position: absolute;
    top: 0;
    left: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
  }

  .firepit-feature-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 150px;
    max-height: 150px;
  }

  .firepit-feature-1-{{ ai_gen_id }} .firepit-feature-image-container-{{ ai_gen_id }} {
    background-color: {{ block.settings.feature_1_background }};
    border: 2px solid {{ block.settings.feature_1_border }};
    border-radius: {{ block.settings.feature_border_radius }}px;
  }

  .firepit-feature-2-{{ ai_gen_id }} .firepit-feature-image-container-{{ ai_gen_id }} {
    background-color: {{ block.settings.feature_2_background }};
    border: 2px solid {{ block.settings.feature_2_border }};
    border-radius: {{ block.settings.feature_border_radius }}px;
  }

  .firepit-feature-3-{{ ai_gen_id }} .firepit-feature-image-container-{{ ai_gen_id }} {
    background-color: {{ block.settings.feature_3_background }};
    border: 2px solid {{ block.settings.feature_3_border }};
    border-radius: {{ block.settings.feature_border_radius }}px;
  }

  .firepit-feature-text-{{ ai_gen_id }} {
    margin-top: 15px;
    font-size: {{ block.settings.feature_text_size }}px;
    color: {{ block.settings.feature_text_color }};
  }

  @media screen and (max-width: 990px) {
    .firepit-container-{{ ai_gen_id }} {
      flex-direction: column;
    }

    .firepit-main-image-container-{{ ai_gen_id }} {
      width: 100%;
      height: 400px;
    }

    .firepit-heading-{{ ai_gen_id }} {
      position: relative;
      top: 0;
      left: 0;
      padding: 20px;
      font-size: calc({{ block.settings.heading_size }}px * 0.8);
      max-width: 100%;
      text-align: center;
      background-color: {{ block.settings.background_color }};
      text-shadow: none;
    }

    .firepit-features-container-{{ ai_gen_id }} {
      width: 100%;
      padding: 20px;
    }

    .firepit-feature-{{ ai_gen_id }} {
      margin-bottom: 30px;
      height: auto;
    }

    .firepit-feature-text-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.feature_text_size }}px * 0.9);
    }
  }

  @media screen and (max-width: 749px) {
    .firepit-heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.6);
    }

    .firepit-main-image-container-{{ ai_gen_id }} {
      height: 300px;
    }

    .firepit-main-image-placeholder-{{ ai_gen_id }} {
      min-height: 300px;
    }

    .firepit-features-container-{{ ai_gen_id }} {
      padding: 15px;
    }

    .firepit-feature-text-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.feature_text_size }}px * 0.8);
    }
  }
{% endstyle %}

<div class="firepit-block-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="firepit-container-{{ ai_gen_id }}">
    <div class="firepit-main-image-container-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h2 class="firepit-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
      {% endif %}
      
      {% if block.settings.main_image %}
        <img 
          src="{{ block.settings.main_image | image_url: width: 1500 }}" 
          alt="{{ block.settings.main_image.alt | escape }}"
          class="firepit-main-image-{{ ai_gen_id }}"
          loading="lazy"
          width="{{ block.settings.main_image.width }}"
          height="{{ block.settings.main_image.height }}"
        >
      {% else %}
        <div class="firepit-main-image-placeholder-{{ ai_gen_id }}">
          {{ 'image' | placeholder_svg_tag }}
        </div>
      {% endif %}
    </div>
    
    <div class="firepit-features-container-{{ ai_gen_id }}">
      <div class="firepit-feature-{{ ai_gen_id }} firepit-feature-1-{{ ai_gen_id }}">
        <div class="firepit-feature-image-container-{{ ai_gen_id }}">
          {% if block.settings.feature_1_image %}
            <img 
              src="{{ block.settings.feature_1_image | image_url: width: 600 }}" 
              alt="{{ block.settings.feature_1_image.alt | escape }}"
              class="firepit-feature-image-{{ ai_gen_id }}"
              loading="lazy"
              width="{{ block.settings.feature_1_image.width }}"
              height="{{ block.settings.feature_1_image.height }}"
            >
          {% else %}
            <div class="firepit-feature-image-placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
            </div>
          {% endif %}
        </div>
        {% if block.settings.feature_1_text != blank %}
          <div class="firepit-feature-text-{{ ai_gen_id }}">{{ block.settings.feature_1_text }}</div>
        {% endif %}
      </div>
      
      <div class="firepit-feature-{{ ai_gen_id }} firepit-feature-2-{{ ai_gen_id }}">
        <div class="firepit-feature-image-container-{{ ai_gen_id }}">
          {% if block.settings.feature_2_image %}
            <img 
              src="{{ block.settings.feature_2_image | image_url: width: 600 }}" 
              alt="{{ block.settings.feature_2_image.alt | escape }}"
              class="firepit-feature-image-{{ ai_gen_id }}"
              loading="lazy"
              width="{{ block.settings.feature_2_image.width }}"
              height="{{ block.settings.feature_2_image.height }}"
            >
          {% else %}
            <div class="firepit-feature-image-placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
            </div>
          {% endif %}
        </div>
        {% if block.settings.feature_2_text != blank %}
          <div class="firepit-feature-text-{{ ai_gen_id }}">{{ block.settings.feature_2_text }}</div>
        {% endif %}
      </div>
      
      <div class="firepit-feature-{{ ai_gen_id }} firepit-feature-3-{{ ai_gen_id }}">
        <div class="firepit-feature-image-container-{{ ai_gen_id }}">
          {% if block.settings.feature_3_image %}
            <img 
              src="{{ block.settings.feature_3_image | image_url: width: 600 }}" 
              alt="{{ block.settings.feature_3_image.alt | escape }}"
              class="firepit-feature-image-{{ ai_gen_id }}"
              loading="lazy"
              width="{{ block.settings.feature_3_image.width }}"
              height="{{ block.settings.feature_3_image.height }}"
            >
          {% else %}
            <div class="firepit-feature-image-placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
            </div>
          {% endif %}
        </div>
        {% if block.settings.feature_3_text != blank %}
          <div class="firepit-feature-text-{{ ai_gen_id }}">{{ block.settings.feature_3_text }}</div>
        {% endif %}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Garden Firepit Block",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Main Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Premium Garden Firepit"
    },
    {
      "type": "image_picker",
      "id": "main_image",
      "label": "Main lifestyle image"
    },
    {
      "type": "header",
      "content": "Feature 1"
    },
    {
      "type": "image_picker",
      "id": "feature_1_image",
      "label": "Feature 1 image"
    },
    {
      "type": "text",
      "id": "feature_1_text",
      "label": "Feature 1 text",
      "default": "Durable cast iron construction"
    },
    {
      "type": "color",
      "id": "feature_1_background",
      "label": "Feature 1 background color",
      "default": "#f9f9f9"
    },
    {
      "type": "color",
      "id": "feature_1_border",
      "label": "Feature 1 border color",
      "default": "#e0e0e0"
    },
    {
      "type": "header",
      "content": "Feature 2"
    },
    {
      "type": "image_picker",
      "id": "feature_2_image",
      "label": "Feature 2 image"
    },
    {
      "type": "text",
      "id": "feature_2_text",
      "label": "Feature 2 text",
      "default": "360° heat distribution"
    },
    {
      "type": "color",
      "id": "feature_2_background",
      "label": "Feature 2 background color",
      "default": "#f9f9f9"
    },
    {
      "type": "color",
      "id": "feature_2_border",
      "label": "Feature 2 border color",
      "default": "#e0e0e0"
    },
    {
      "type": "header",
      "content": "Feature 3"
    },
    {
      "type": "image_picker",
      "id": "feature_3_image",
      "label": "Feature 3 image"
    },
    {
      "type": "text",
      "id": "feature_3_text",
      "label": "Feature 3 text",
      "default": "Easy assembly, no tools required"
    },
    {
      "type": "color",
      "id": "feature_3_background",
      "label": "Feature 3 background color",
      "default": "#f9f9f9"
    },
    {
      "type": "color",
      "id": "feature_3_border",
      "label": "Feature 3 border color",
      "default": "#e0e0e0"
    },
    {
      "type": "header",
      "content": "Style Settings"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 24,
      "max": 72,
      "step": 2,
      "unit": "px",
      "label": "Heading size",
      "default": 42
    },
    {
      "type": "color",
      "id": "feature_text_color",
      "label": "Feature text color",
      "default": "#333333"
    },
    {
      "type": "range",
      "id": "feature_text_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Feature text size",
      "default": 16
    },
    {
      "type": "range",
      "id": "feature_border_radius",
      "min": 0,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Feature border radius",
      "default": 8
    }
  ],
  "presets": [
    {
      "name": "Garden Firepit Block"
    }
  ]
}
{% endschema %}