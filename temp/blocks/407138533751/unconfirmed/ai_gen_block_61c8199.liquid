{% doc %}
  @prompt
    I want an image carousel section with dynamic source options available. The carousel needs to be 4 images displayed on desktop and just 1 on mobile, with a scroller. If there is not at least 4 pieces of data present in the dynamic source, the section will not display on desktop and if there is no data present whatsoever (less than 1), then the section won't appear on mobile either. The carousel should be on infinite scroll. I need sizing and padding options, as well as a title option at the top of the section. 

{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% liquid
  case block.settings.image_source
    when 'collection'
      if block.settings.collection != blank
        assign source_items = block.settings.collection.products
        assign source_type = 'product'
      else
        assign source_items = collections.all.products | slice: 0, 8
        assign source_type = 'product'
      endif
    when 'blog'
      if block.settings.blog != blank
        assign source_items = block.settings.blog.articles
        assign source_type = 'article'
      else
        assign source_items = blog.articles | slice: 0, 8
        assign source_type = 'article'
      endif
    when 'manual'
      assign manual_images = ''
      for i in (1..8)
        assign image_key = 'manual_image_' | append: i
        assign image = block.settings[image_key]
        if image != blank
          assign manual_images = manual_images | append: image.id | append: ','
        endif
      endfor
      assign source_items = manual_images | split: ','
      assign source_type = 'manual'
  endcase

  assign items_count = source_items.size
  if source_type == 'manual'
    assign items_count = source_items.size | minus: 1
  endif
%}

{% comment %} Hide section based on item count {% endcomment %}
{% assign show_desktop = false %}
{% assign show_mobile = false %}

{% if items_count >= 4 %}
  {% assign show_desktop = true %}
{% endif %}

{% if items_count >= 1 %}
  {% assign show_mobile = true %}
{% endif %}

{% if show_desktop == false and show_mobile == false %}
  {% comment %} Don't render anything if no items {% endcomment %}
{% else %}

{% style %}
  .ai-image-carousel-{{ ai_gen_id }} {
    padding: {{ block.settings.section_padding_top }}px 0 {{ block.settings.section_padding_bottom }}px;
  }

  .ai-image-carousel-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-image-carousel-title-{{ ai_gen_id }} {
    text-align: center;
    margin: 0 0 {{ block.settings.title_spacing }}px;
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
  }

  .ai-image-carousel-wrapper-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
  }

  .ai-image-carousel-track-{{ ai_gen_id }} {
    display: flex;
    transition: transform 0.5s ease;
    will-change: transform;
  }

  .ai-image-carousel-slide-{{ ai_gen_id }} {
    flex: 0 0 25%;
    padding: 0 {{ block.settings.image_spacing | divided_by: 2 }}px;
  }

  .ai-image-carousel-image-container-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: {{ block.settings.image_height }}px;
    border-radius: {{ block.settings.border_radius }}px;
    overflow: hidden;
  }

  .ai-image-carousel-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-image-carousel-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-image-carousel-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-image-carousel-nav-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: {{ block.settings.nav_background }};
    border: none;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
    transition: opacity 0.3s ease;
  }

  .ai-image-carousel-nav-{{ ai_gen_id }}:hover {
    opacity: 0.8;
  }

  .ai-image-carousel-nav-prev-{{ ai_gen_id }} {
    left: 10px;
  }

  .ai-image-carousel-nav-next-{{ ai_gen_id }} {
    right: 10px;
  }

  .ai-image-carousel-nav-{{ ai_gen_id }} svg {
    width: 20px;
    height: 20px;
    fill: {{ block.settings.nav_arrow_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-image-carousel-{{ ai_gen_id }} {
      {% unless show_mobile %}
        display: none;
      {% endunless %}
    }

    .ai-image-carousel-slide-{{ ai_gen_id }} {
      flex: 0 0 100%;
    }

    .ai-image-carousel-nav-{{ ai_gen_id }} {
      display: none;
    }
  }

  @media screen and (min-width: 750px) {
    .ai-image-carousel-{{ ai_gen_id }} {
      {% unless show_desktop %}
        display: none;
      {% endunless %}
    }
  }

  @media screen and (max-width: 1024px) and (min-width: 750px) {
    .ai-image-carousel-slide-{{ ai_gen_id }} {
      flex: 0 0 33.333%;
    }
  }
{% endstyle %}

<image-carousel-{{ ai_gen_id }}
  class="ai-image-carousel-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
  data-autoplay="{{ block.settings.autoplay }}"
  data-autoplay-speed="{{ block.settings.autoplay_speed }}"
>
  <div class="ai-image-carousel-container-{{ ai_gen_id }}">
    {% if block.settings.title != blank %}
      <h2 class="ai-image-carousel-title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
    {% endif %}

    <div class="ai-image-carousel-wrapper-{{ ai_gen_id }}">
      <div class="ai-image-carousel-track-{{ ai_gen_id }}">
        {% case source_type %}
          {% when 'product' %}
            {% for product in source_items limit: 20 %}
              <div class="ai-image-carousel-slide-{{ ai_gen_id }}">
                <div class="ai-image-carousel-image-container-{{ ai_gen_id }}">
                  {% if product.featured_image %}
                    <img
                      src="{{ product.featured_image | image_url: width: 600 }}"
                      alt="{{ product.featured_image.alt | escape }}"
                      class="ai-image-carousel-image-{{ ai_gen_id }}"
                      loading="lazy"
                      width="600"
                      height="{{ block.settings.image_height }}"
                    >
                  {% else %}
                    <div class="ai-image-carousel-placeholder-{{ ai_gen_id }}">
                      {{ 'product-1' | placeholder_svg_tag }}
                    </div>
                  {% endif %}
                </div>
              </div>
            {% endfor %}

          {% when 'article' %}
            {% for article in source_items limit: 20 %}
              <div class="ai-image-carousel-slide-{{ ai_gen_id }}">
                <div class="ai-image-carousel-image-container-{{ ai_gen_id }}">
                  {% if article.image %}
                    <img
                      src="{{ article.image | image_url: width: 600 }}"
                      alt="{{ article.image.alt | escape }}"
                      class="ai-image-carousel-image-{{ ai_gen_id }}"
                      loading="lazy"
                      width="600"
                      height="{{ block.settings.image_height }}"
                    >
                  {% else %}
                    <div class="ai-image-carousel-placeholder-{{ ai_gen_id }}">
                      {{ 'image' | placeholder_svg_tag }}
                    </div>
                  {% endif %}
                </div>
              </div>
            {% endfor %}

          {% when 'manual' %}
            {% for i in (1..8) %}
              {% assign image_key = 'manual_image_' | append: i %}
              {% assign image = block.settings[image_key] %}
              {% if image != blank %}
                <div class="ai-image-carousel-slide-{{ ai_gen_id }}">
                  <div class="ai-image-carousel-image-container-{{ ai_gen_id }}">
                    <img
                      src="{{ image | image_url: width: 600 }}"
                      alt="{{ image.alt | escape }}"
                      class="ai-image-carousel-image-{{ ai_gen_id }}"
                      loading="lazy"
                      width="600"
                      height="{{ block.settings.image_height }}"
                    >
                  </div>
                </div>
              {% endif %}
            {% endfor %}
        {% endcase %}
      </div>

      <button class="ai-image-carousel-nav-{{ ai_gen_id }} ai-image-carousel-nav-prev-{{ ai_gen_id }}" aria-label="Previous image">
        <svg viewBox="0 0 24 24">
          <path d="M15 18l-6-6 6-6"/>
        </svg>
      </button>

      <button class="ai-image-carousel-nav-{{ ai_gen_id }} ai-image-carousel-nav-next-{{ ai_gen_id }}" aria-label="Next image">
        <svg viewBox="0 0 24 24">
          <path d="M9 18l6-6-6-6"/>
        </svg>
      </button>
    </div>
  </div>
</image-carousel-{{ ai_gen_id }}>

<script>
(function() {
  class ImageCarousel{{ ai_gen_id }} extends HTMLElement {
    constructor() {
      super();
      this.currentIndex = 0;
      this.autoplayInterval = null;
      this.isTransitioning = false;
    }

    connectedCallback() {
      this.track = this.querySelector('.ai-image-carousel-track-{{ ai_gen_id }}');
      this.slides = this.querySelectorAll('.ai-image-carousel-slide-{{ ai_gen_id }}');
      this.prevBtn = this.querySelector('.ai-image-carousel-nav-prev-{{ ai_gen_id }}');
      this.nextBtn = this.querySelector('.ai-image-carousel-nav-next-{{ ai_gen_id }}');
      
      this.slidesPerView = this.getSlidesPerView();
      this.totalSlides = this.slides.length;
      
      if (this.totalSlides === 0) return;

      this.cloneSlides();
      this.setupEventListeners();
      this.updateCarousel();
      
      if (this.dataset.autoplay === 'true') {
        this.startAutoplay();
      }

      window.addEventListener('resize', this.handleResize.bind(this));
    }

    getSlidesPerView() {
      return window.innerWidth >= 1025 ? 4 : window.innerWidth >= 750 ? 3 : 1;
    }

    cloneSlides() {
      const slidesToClone = Math.max(this.slidesPerView, 4);
      
      for (let i = 0; i < slidesToClone; i++) {
        const firstClone = this.slides[i % this.totalSlides].cloneNode(true);
        const lastClone = this.slides[(this.totalSlides - 1 - i % this.totalSlides)].cloneNode(true);
        
        firstClone.classList.add('clone');
        lastClone.classList.add('clone');
        
        this.track.appendChild(firstClone);
        this.track.insertBefore(lastClone, this.track.firstChild);
      }
      
      this.allSlides = this.querySelectorAll('.ai-image-carousel-slide-{{ ai_gen_id }}');
      this.currentIndex = slidesToClone;
    }

    setupEventListeners() {
      this.prevBtn?.addEventListener('click', () => this.prevSlide());
      this.nextBtn?.addEventListener('click', () => this.nextSlide());
      
      this.track.addEventListener('transitionend', () => {
        this.isTransitioning = false;
        this.handleInfiniteLoop();
      });

      this.addEventListener('mouseenter', () => this.stopAutoplay());
      this.addEventListener('mouseleave', () => {
        if (this.dataset.autoplay === 'true') {
          this.startAutoplay();
        }
      });
    }

    updateCarousel() {
      if (this.isTransitioning) return;
      
      const slideWidth = 100 / this.slidesPerView;
      const translateX = -this.currentIndex * slideWidth;
      this.track.style.transform = `translateX(${translateX}%)`;
    }

    nextSlide() {
      if (this.isTransitioning) return;
      this.isTransitioning = true;
      this.currentIndex++;
      this.updateCarousel();
    }

    prevSlide() {
      if (this.isTransitioning) return;
      this.isTransitioning = true;
      this.currentIndex--;
      this.updateCarousel();
    }

    handleInfiniteLoop() {
      const slidesToClone = Math.max(this.slidesPerView, 4);
      
      if (this.currentIndex >= this.totalSlides + slidesToClone) {
        this.track.style.transition = 'none';
        this.currentIndex = slidesToClone;
        this.updateCarousel();
        setTimeout(() => {
          this.track.style.transition = 'transform 0.5s ease';
        }, 10);
      } else if (this.currentIndex < slidesToClone) {
        this.track.style.transition = 'none';
        this.currentIndex = this.totalSlides + slidesToClone - 1;
        this.updateCarousel();
        setTimeout(() => {
          this.track.style.transition = 'transform 0.5s ease';
        }, 10);
      }
    }

    startAutoplay() {
      this.stopAutoplay();
      const speed = parseInt(this.dataset.autoplaySpeed) || 3000;
      this.autoplayInterval = setInterval(() => {
        this.nextSlide();
      }, speed);
    }

    stopAutoplay() {
      if (this.autoplayInterval) {
        clearInterval(this.autoplayInterval);
        this.autoplayInterval = null;
      }
    }

    handleResize() {
      const newSlidesPerView = this.getSlidesPerView();
      if (newSlidesPerView !== this.slidesPerView) {
        this.slidesPerView = newSlidesPerView;
        this.updateCarousel();
      }
    }

    disconnectedCallback() {
      this.stopAutoplay();
      window.removeEventListener('resize', this.handleResize.bind(this));
    }
  }

  customElements.define('image-carousel-{{ ai_gen_id }}', ImageCarousel{{ ai_gen_id }});
})();
</script>

{% endif %}

