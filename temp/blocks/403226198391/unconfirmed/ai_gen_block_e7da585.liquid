{% doc %}
  @prompt
    Remake the Product Feature Tabs in this block, but display the price of each set near the add to cart, so thag it switches as you switch tabs, allowing a connected product within each of the 4 tabs, for example The Kensington, I would add the Kensington Product, so when that product tab is selected, the price and title of the kensington display next to the add to cart button and whern you click add to cart, it adds that product to the cart. 

{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .product-tabs-{{ ai_gen_id }} {
    width: 100%;
    margin: 0 auto;
  }

  .product-tabs__header-{{ ai_gen_id }} {
    display: flex;
    flex-wrap: wrap;
    gap: 2px;
    margin-bottom: 20px;
    border-bottom: 1px solid {{ block.settings.tab_border_color }};
  }

  .product-tabs__tab-{{ ai_gen_id }} {
    padding: 12px 20px;
    background-color: {{ block.settings.tab_background_color }};
    color: {{ block.settings.tab_text_color }};
    border: none;
    cursor: pointer;
    transition: background-color 0.3s;
    font-weight: 500;
    position: relative;
  }

  .product-tabs__tab-{{ ai_gen_id }}::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 3px;
    background-color: {{ block.settings.tab_active_color }};
    transform: scaleX(0);
    transition: transform 0.3s;
  }

  .product-tabs__tab-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.tab_hover_color }};
  }

  .product-tabs__tab-{{ ai_gen_id }}.active {
    color: {{ block.settings.tab_active_text_color }};
  }

  .product-tabs__tab-{{ ai_gen_id }}.active::after {
    transform: scaleX(1);
  }

  .product-tabs__content-{{ ai_gen_id }} {
    display: none;
    padding: 20px;
    background-color: {{ block.settings.content_background_color }};
    border-radius: 0 0 4px 4px;
  }

  .product-tabs__content-{{ ai_gen_id }}.active {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  @media screen and (min-width: 768px) {
    .product-tabs__content-{{ ai_gen_id }}.active {
      flex-direction: row;
    }
  }

  .product-tabs__content-text-{{ ai_gen_id }} {
    flex: 1;
  }

  .product-tabs__content-image-{{ ai_gen_id }} {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .product-tabs__content-image-{{ ai_gen_id }} img {
    max-width: 100%;
    height: auto;
    border-radius: 4px;
  }

  .product-tabs__image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 300px;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 4px;
  }

  .product-tabs__image-placeholder-{{ ai_gen_id }} svg {
    width: 50%;
    height: 50%;
    opacity: 0.5;
  }

  .product-tabs__title-{{ ai_gen_id }} {
    margin-top: 0;
    margin-bottom: 15px;
    color: {{ block.settings.title_color }};
    font-size: 24px;
  }

  .product-tabs__description-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    line-height: 1.6;
  }

  .product-tabs__purchase-{{ ai_gen_id }} {
    margin-top: 20px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  @media screen and (min-width: 768px) {
    .product-tabs__purchase-{{ ai_gen_id }} {
      flex-direction: row;
      align-items: center;
    }
  }

  .product-tabs__product-info-{{ ai_gen_id }} {
    flex: 1;
  }

  .product-tabs__product-title-{{ ai_gen_id }} {
    font-weight: 600;
    margin-bottom: 5px;
    color: {{ block.settings.title_color }};
  }

  .product-tabs__product-price-{{ ai_gen_id }} {
    font-weight: 600;
    font-size: 18px;
    color: {{ block.settings.price_color }};
  }

  .product-tabs__add-to-cart-{{ ai_gen_id }} {
    padding: 12px 24px;
    background-color: {{ block.settings.button_background_color }};
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: 4px;
    cursor: pointer;
    font-weight: 600;
    transition: background-color 0.3s;
  }

  .product-tabs__add-to-cart-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
  }

  .product-tabs__add-to-cart-{{ ai_gen_id }}:disabled {
    background-color: #cccccc;
    cursor: not-allowed;
  }
{% endstyle %}

<div class="product-tabs-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="product-tabs__header-{{ ai_gen_id }}">
    {% for i in (1..4) %}
      {% assign tab_title_key = 'tab_' | append: i | append: '_title' %}
      {% assign tab_title = block.settings[tab_title_key] %}
      {% if tab_title != blank %}
        <button 
          class="product-tabs__tab-{{ ai_gen_id }} {% if forloop.first %}active{% endif %}" 
          data-tab="{{ i }}"
          aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
          role="tab"
          aria-controls="tab-content-{{ i }}-{{ ai_gen_id }}"
          id="tab-{{ i }}-{{ ai_gen_id }}"
        >
          {{ tab_title }}
        </button>
      {% endif %}
    {% endfor %}
  </div>

  {% for i in (1..4) %}
    {% assign tab_title_key = 'tab_' | append: i | append: '_title' %}
    {% assign tab_content_key = 'tab_' | append: i | append: '_content' %}
    {% assign tab_image_key = 'tab_' | append: i | append: '_image' %}
    {% assign tab_product_key = 'tab_' | append: i | append: '_product' %}
    
    {% assign tab_title = block.settings[tab_title_key] %}
    {% assign tab_content = block.settings[tab_content_key] %}
    {% assign tab_image = block.settings[tab_image_key] %}
    {% assign tab_product = block.settings[tab_product_key] %}
    
    {% if tab_title != blank %}
      <div 
        class="product-tabs__content-{{ ai_gen_id }} {% if forloop.first %}active{% endif %}" 
        id="tab-content-{{ i }}-{{ ai_gen_id }}"
        role="tabpanel"
        aria-labelledby="tab-{{ i }}-{{ ai_gen_id }}"
        {% unless forloop.first %}hidden{% endunless %}
      >
        <div class="product-tabs__content-text-{{ ai_gen_id }}">
          <h3 class="product-tabs__title-{{ ai_gen_id }}">{{ tab_title }}</h3>
          <div class="product-tabs__description-{{ ai_gen_id }}">{{ tab_content }}</div>
          
          <div class="product-tabs__purchase-{{ ai_gen_id }}">
            <div class="product-tabs__product-info-{{ ai_gen_id }}">
              {% if tab_product != blank %}
                <div class="product-tabs__product-title-{{ ai_gen_id }}">{{ tab_product.title }}</div>
                <div class="product-tabs__product-price-{{ ai_gen_id }}">{{ tab_product.price | money }}</div>
              {% endif %}
            </div>
            
            <button 
              class="product-tabs__add-to-cart-{{ ai_gen_id }}" 
              data-product-id="{{ tab_product.id }}"
              data-variant-id="{{ tab_product.selected_or_first_available_variant.id }}"
              {% if tab_product == blank or tab_product.available == false %}disabled{% endif %}
            >
              {% if tab_product != blank and tab_product.available %}
                {{ block.settings.add_to_cart_text }}
              {% else %}
                Sold Out
              {% endif %}
            </button>
          </div>
        </div>
        
        <div class="product-tabs__content-image-{{ ai_gen_id }}">
          {% if tab_image != blank %}
            <img 
              src="{{ tab_image | image_url: width: 600 }}" 
              alt="{{ tab_title }}"
              loading="lazy"
              width="{{ tab_image.width }}"
              height="{{ tab_image.height }}"
            >
          {% else %}
            <div class="product-tabs__image-placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
            </div>
          {% endif %}
        </div>
      </div>
    {% endif %}
  {% endfor %}
</div>

<script>
  (function() {
    class ProductTabs extends HTMLElement {
      constructor() {
        super();
        this.tabs = this.querySelectorAll('.product-tabs__tab-{{ ai_gen_id }}');
        this.contents = this.querySelectorAll('.product-tabs__content-{{ ai_gen_id }}');
        this.addToCartButtons = this.querySelectorAll('.product-tabs__add-to-cart-{{ ai_gen_id }}');
      }

      connectedCallback() {
        this.setupTabs();
        this.setupAddToCart();
      }

      setupTabs() {
        this.tabs.forEach(tab => {
          tab.addEventListener('click', () => {
            const tabId = tab.getAttribute('data-tab');
            
            // Update tab states
            this.tabs.forEach(t => {
              t.classList.remove('active');
              t.setAttribute('aria-selected', 'false');
            });
            tab.classList.add('active');
            tab.setAttribute('aria-selected', 'true');
            
            // Update content visibility
            this.contents.forEach(content => {
              content.classList.remove('active');
              content.setAttribute('hidden', '');
            });
            
            const activeContent = this.querySelector(`#tab-content-${tabId}-{{ ai_gen_id }}`);
            if (activeContent) {
              activeContent.classList.add('active');
              activeContent.removeAttribute('hidden');
            }
          });
        });
      }

      setupAddToCart() {
        this.addToCartButtons.forEach(button => {
          if (button.disabled) return;
          
          button.addEventListener('click', () => {
            const productId = button.getAttribute('data-product-id');
            const variantId = button.getAttribute('data-variant-id');
            
            if (!productId || !variantId) return;
            
            button.textContent = 'Adding...';
            button.disabled = true;
            
            const formData = {
              'items': [{
                'id': variantId,
                'quantity': 1
              }]
            };
            
            fetch('/cart/add.js', {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json'
              },
              body: JSON.stringify(formData)
            })
            .then(response => response.json())
            .then(data => {
              button.textContent = '{{ block.settings.added_to_cart_text }}';
              setTimeout(() => {
                button.textContent = '{{ block.settings.add_to_cart_text }}';
                button.disabled = false;
              }, 2000);
              
              // Refresh cart drawer/page if needed
              if (typeof window.refreshCart === 'function') {
                window.refreshCart();
              }
            })
            .catch(error => {
              console.error('Error:', error);
              button.textContent = 'Error';
              setTimeout(() => {
                button.textContent = '{{ block.settings.add_to_cart_text }}';
                button.disabled = false;
              }, 2000);
            });
          });
        });
      }
    }

    customElements.define('product-feature-tabs-{{ ai_gen_id }}', ProductTabs);

    // Initialize the component
    const productTabsContainer = document.querySelector('.product-tabs-{{ ai_gen_id }}');
    if (productTabsContainer && !productTabsContainer.matches(':defined')) {
      const productTabs = document.createElement('product-feature-tabs-{{ ai_gen_id }}');
      productTabsContainer.parentNode.replaceChild(productTabs, productTabsContainer);
      productTabs.appendChild(productTabsContainer);
    }
  })();
</script>

