<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="">
    <link rel="canonical" href="{{ canonical_url }}">
    <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>
    {%- unless settings.type_header_font.system? and settings.type_body_font.system? -%}
      <link rel="preconnect" href="https://fonts.shopifycdn.com" crossorigin>
    {%- endunless -%}
    {%- if settings.favicon != blank -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    {%- endif -%}
    <title>
      {{ page_title }}
      {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
      {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
      {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
    </title>

    {% if page_description %}
      <meta name="description" content="{{ page_description | escape }}">
    {% endif %}

    {% render 'meta-tags' %}
    {% render 'global-style' %}
    {{ content_for_header }}
    {{ 'vendor.css' | asset_url | stylesheet_tag: preload: true }}
    {{ 'base.css' | asset_url | stylesheet_tag: preload: true }}
    {{ 'collections-arrows.css' | asset_url | stylesheet_tag: preload: true }}
    <script src="{{ 'constants.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'pubsub.js' | asset_url }}" defer="defer"></script>
    {%- if settings.animations_reveal_on_scroll -%}
      <script src="{{ 'animations.js' | asset_url }}" defer="defer"></script>
    {%- endif -%}

    {% render 'global-script' %}
    <script src="https://shopoe.net/app.js" defer="defer"></script>
    <script src="https://sdk.snapfinance.co.uk/v1/snapuk.min.js" defer="defer"></script>
    {% comment %} <script type="text/javascript">
      (function(c,l,a,r,i,t,y){
          c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
          t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
          y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
      })(window, document, "clarity", "script", "g4fmvmhh6m");
    </script> {% endcomment %}
  </head>
  <body class="page-{{ request.page_type | replace: 'customers/', '' }} gradient {{ settings.text_size | prepend: 'text-size main-text-' }} {{ settings.heading_size | prepend: 'heading-size main-heading-' }}{% if settings.enable_animated_cursor and settings.animated_cursor_style == 'following' %} cursor-fixed__show{% endif %}{% if settings.animations_hover_elements != 'none' %} animate--hover-{{ settings.animations_hover_elements }}{% endif %}">
    <a class="skip-to-content-link button visually-hidden" href="#MainContent">
      {{ "accessibility.skip_to_text" | t }}
    </a>
    {% render 'preload-screen' %}
    {%- if settings.enable_animated_cursor -%}
      {% render 'cursor-fixed', style_cursor: settings.animated_cursor_style %}
    {%- endif -%}
    {% sections 'header-group' %}
    <main id="MainContent" class="content-for-layout focus-none" role="main" tabindex="-1">
      {{ content_for_layout }}
    </main>
    {% sections 'footer-group' %}
    {%- sections 'popup-group' -%}
    {% render 'multitasking-bar' %}
    <ul hidden>
      <li id="a11y-refresh-page-message">{{ 'accessibility.refresh_page' | t }}</li>
      <li id="a11y-new-window-message">{{ 'accessibility.link_messages.new_window' | t }}</li>
    </ul>

    {% comment %} VENDOR SCRIPTS {% endcomment %}
    {% comment %} <script src="{{ 'vendor.js' | asset_url }}" defer="defer"></script> {% endcomment %}

    {%- unless template contains == 'collection' -%}
      <script src="{{ 'swiper.js' | asset_url }}" defer="defer"></script>
    {%- endunless -%}

    {% comment %} <script src="{{ 'GSAP.js' | asset_url }}" defer="defer"></script> {% endcomment %}
    <script src="{{ 'ScrollTrigger.js' | asset_url }}" defer="defer"></script>
    {% comment %} <script src="{{ 'splitting.js' | asset_url }}" defer="defer"></script> {% endcomment %}
    {% comment %} <script src="{{ 'lightgallery1.js' | asset_url }}" defer="defer"></script> {% endcomment %}
    {% comment %} <script src="{{ 'lightgallery2.js' | asset_url }}" defer="defer"></script> {% endcomment %}
    {% comment %} <script src="{{ 'lightgallery3.js' | asset_url }}" defer="defer"></script> {% endcomment %}

    {% comment %} GLOBAL SCRIPTS {% endcomment %}
    {% comment %} <script src="{{ 'global.js' | asset_url }}" defer="defer"></script> {% endcomment %}

    <script src="https://ajax.googleapis.com/ajax/libs/jquery/1.9.1/jquery.min.js" defer="defer"></script>

    <script src="{{ 'GlobalBasics.js' | asset_url }}" defer="defer"></script>
        
    <script src="{{ 'Common.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'AnimateElement.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'AnnouncementBar.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'AZBrands.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'AZLayout.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'BeforeAfterCursor.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'CountDown.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'CountDownSpecial.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'CustomTab.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'DeferredMedia.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'DetailsDisclosure.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'HeaderTools.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'FooterCollapse.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'LocalizationForm.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'MenuDrawer.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'HeaderDrawer.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'HoverShow.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'CursorMove.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'ImageReveal.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'HoverChangeImage.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'LookbookPoint.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'MapTemplate.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'ModalTools.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'PageDrawer.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'ProductRecommendations.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'QuantityInput.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'SearchForm.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'ShowMoreButton.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'DrawerOpeners.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'PreloadScreen.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'SliderComponent.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'SliderComponentProduct.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'CategorySlide.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'AnchorTarget.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'SlideshowComponent.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'StickyHeader.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'ThemeSwiper.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'ThemeTab.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'VariantTools.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'VideoTools.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'ProductCustomerViewing.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'WriteComment.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'Parallax.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'CollapseCollection.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'SplittingAnimate.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'Gallery.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'NewsletterForm.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'ButtonRipple.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'BundleTools.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'ScrollContainerCenter.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'cartTools.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'shippingCalculator.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'wishlistCard.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'wishlistDrawer.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'cursorFixed.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'cursorBlur.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'pageLoadScrollFix.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'trustpilotServiceReviewStars.js' | asset_url }}" defer="defer"></script>

    {%- unless template != 'product' -%}
      <script src="{{ 'productPage.js' | asset_url }}" defer="defer"></script>
      <script src="{{ 'ufurnish.js' | asset_url }}" defer="defer"></script>
    {%- endunless -%}

    {%- if settings.predictive_search_enabled -%}
      <script src="{{ 'predictive-search.js' | asset_url }}" defer="defer"></script>
    {%- endif -%}
    <link rel="stylesheet" href="{{ 'animation.css' | asset_url }}" media="print" onload="this.media='all'">
  </body>
</html>
