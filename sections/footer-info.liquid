<section
  class="text-center {% if section.settings.section_width == 'page-width' %}page-width{% endif %}"
  style="
    margin-top: {{ section.settings.section_margin }}px;
    margin-bottom: {{ section.settings.section_margin }}px;
    {% if section.settings.section_width == 'customized-width' %}
      max-width: {{ section.settings.customize_width }}px;
      margin-left: auto;
      margin-right: auto;
    {% endif %}
    font-size: {{ section.settings.font_size }}px;
  "
>
  {{ section.settings.text }}
</section>

{% schema %}
{
  "name": "Footer Info",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "select",
      "id": "section_width",
      "options": [
        {
          "value": "full-width",
          "label": "t:sections.all.section_width.options__1"
        },
        {
          "value": "page-width",
          "label": "t:sections.all.section_width.options__2"
        },
        {
          "value": "customized-width",
          "label": "t:sections.all.section_width.options__3"
        }
      ],
      "default": "customized-width",
      "label": "t:sections.all.section_width.label"
    },
    {
      "type": "range",
      "id": "customize_width",
      "min": 1000,
      "max": 1800,
      "step": 50,
      "default": 1400,
      "unit": "px",
      "label": "t:sections.all.customize_width.label"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "background-1"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top_mobile",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom_mobile",
      "default": 0
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text"
    },
    {
      "id": "font_size",
      "type": "range",
      "min": 1,
      "max": 50,
      "step": 1,
      "unit": "pt",
      "label": "t:sections.main-product.blocks.color_swatch.settings.font_size",
      "default": 13
    }
  ],
  "presets": [
    {
      "name": "Footer Info"
    }
  ]
}
{% endschema %}
