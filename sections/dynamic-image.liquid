<div
  class="responsive-image-switcher {{ section.settings.section_width }} m-auto{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
  {% if section.settings.section_width == 'customized-width' %}
    style="--page-width: {{ section.settings.customize_width }}px;"
  {% endif %}
>
  {% if section.settings.desktop_image %}
    <img
      src="{{ section.settings.desktop_image | image_url: width: 1600 }}"
      alt="{{ section.settings.alt_text }}"
      class="d-none d-md-block"
      loading="lazy"
      width="100%"
      height="100%"
    >
  {% endif %}

  {% if section.settings.mobile_image %}
    <img
      src="{{ section.settings.mobile_image | image_url: width: 800 }}"
      alt="{{ section.settings.alt_text }}"
      class="d-block d-md-none"
      loading="lazy"
      width="100%"
      height="100%"
    >
  {% endif %}
</div>

{% schema %}
{
  "name": "Dynamic Image",
  "settings": [
    {
      "type": "select",
      "id": "section_width",
      "options": [
        {
          "value": "full-width",
          "label": "t:sections.all.section_width.options__1"
        },
        {
          "value": "page-width",
          "label": "t:sections.all.section_width.options__2"
        },
        {
          "value": "customized-width",
          "label": "t:sections.all.section_width.options__3"
        }
      ],
      "default": "page-width",
      "label": "t:sections.all.section_width.label"
    },
    {
      "type": "range",
      "id": "customize_width",
      "min": 1000,
      "max": 1800,
      "step": 50,
      "default": 1800,
      "unit": "px",
      "label": "t:sections.all.customize_width.label"
    },
    {
      "type": "image_picker",
      "id": "desktop_image",
      "label": "Desktop Image"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile Image"
    },
    {
      "type": "text",
      "id": "alt_text",
      "label": "Alt Text",
      "default": "Responsive image"
    }
  ],
  "presets": [
    {
      "name": "Dynamic Image"
    }
  ]
}
{% endschema %}

{% style %}
  .responsive-image-switcher img {
    width: 100%;
  }
{% endstyle %}
