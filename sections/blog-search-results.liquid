{% assign terms = search.terms | escape %}
{% assign results = search.results | where: "object_type", "article" %}

<div class="blog-search-results-page">
  <h1>Search results for “{{ terms }}”</h1>

  {% if results.size > 0 %}
    <ul class="blog-results-list">
      {% for item in results %}
        <li class="blog-result">
          <a href="{{ item.url | escape }}">{{ item.title | escape }}</a>
          <p>{{ item.excerpt | strip_html | truncate: 150 }}</p>
        </li>
      {% endfor %}
    </ul>
  {% else %}
    <p>No blog posts found for “{{ terms }}”.</p>
  {% endif %}
</div>

{% schema %}
{
  "name": "Blog Search Results",
  "tag": "section",
  "class": "section",
  "settings": [
  {
    "type": "header",
    "content": "t:sections.main-search.settings.header__1.content"
  },
  {
    "type": "checkbox",
    "id": "enable_filtering",
    "default": true,
    "label": "t:sections.main-collection-product-grid.settings.enable_filtering.label",
    "info": "t:sections.main-collection-product-grid.settings.enable_filtering.info"
  },
  {
    "type": "select",
    "id": "filter_type",
    "options": [
    {
      "value": "horizontal",
      "label": "t:sections.main-collection-product-grid.settings.filter_type.options__1"
    },
    {
      "value": "vertical",
      "label": "t:sections.main-collection-product-grid.settings.filter_type.options__2"
    },
    {
      "value": "drawer",
      "label": "t:sections.main-collection-product-grid.settings.filter_type.options__3"
    }],
    "default": "horizontal",
    "label": "t:sections.main-collection-product-grid.settings.filter_type.label",
    "info": "t:sections.main-collection-product-grid.settings.filter_type.info"
  },
  {
    "type": "checkbox",
    "id": "enable_sorting",
    "default": true,
    "label": "t:sections.main-collection-product-grid.settings.enable_sorting.label"
  },
  {
    "type": "select",
    "id": "sorting_style",
    "options": [
    {
      "value": "default",
      "label": "t:sections.main-collection-product-grid.settings.enable_sorting.style.options__1"
    },
    {
      "value": "text-inside",
      "label": "t:sections.main-collection-product-grid.settings.enable_sorting.style.options__2"
    },
    {
      "value": "text-outside",
      "label": "t:sections.main-collection-product-grid.settings.enable_sorting.style.options__3"
    }],
    "default": "default",
    "label": "t:sections.main-collection-product-grid.settings.enable_sorting.style.label"
  },
  {
    "type": "text",
    "id": "swatch",
    "label": "t:sections.main-collection-product-grid.settings.swatch.label",
    "default": "Color"
  },
  {
    "type": "text",
    "id": "pill",
    "label": "t:sections.main-collection-product-grid.settings.pill.label",
    "default": "Size"
  },
  {
    "type": "header",
    "content": "t:sections.main-search.settings.header__2.content",
    "info": "t:sections.main-search.settings.header__2.info"
  },
  {
    "type": "checkbox",
    "id": "article_show_date",
    "default": true,
    "label": "t:sections.main-search.settings.article_show_date.label"
  },
  {
    "type": "checkbox",
    "id": "article_show_author",
    "default": false,
    "label": "t:sections.main-search.settings.article_show_author.label"
  },
  {
    "type": "color_scheme",
    "id": "color_scheme",
    "label": "t:sections.all.colors.label",
    "default": "background-1"
  },
  {
    "type": "header",
    "content": "t:sections.all.padding.section_padding_heading"
  },
  {
    "type": "range",
    "id": "padding_top",
    "min": 0,
    "max": 100,
    "step": 1,
    "unit": "px",
    "label": "t:sections.all.padding.padding_top",
    "default": 36
  },
  {
    "type": "range",
    "id": "padding_bottom",
    "min": 0,
    "max": 100,
    "step": 1,
    "unit": "px",
    "label": "t:sections.all.padding.padding_bottom",
    "default": 36
  }]
}
{% endschema %}
