<div class="container-fluid"
  style="--padding-top: {{ section.settings.padding_top }}px;
    --padding-bottom: {{ section.settings.padding_bottom }}px;
    --padding-top-xs: {{ section.settings.padding_top_mobile }}px;
    --padding-bottom-xs: {{ section.settings.padding_bottom_mobile }}px;
">
  <div class="row">
    <div class="col-12 center p22-stickley-pro-text">As Seen In:</div>
    <div class="col-4">Image</div>
    <div class="col-4">Image</div>
    <div class="col-4">Image</div>
  </div>
</div>

{% schema %}
{
  "name": "As Seen In",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer", "custom.popup"]
  },  
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.all.heading.label",
      "default": "As Seen In"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top_mobile",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom_mobile",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "as_seen_in",
      "name": "t:sections.main-product.blocks.drawer.name",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "default": "Drawer heading",
          "label": "t:sections.all.heading.label",
          "info": "t:sections.all.heading.info__1"
        },
        {
          "type": "select",
          "id": "content_type",
          "label": "t:sections.all.select_content.label",
          "options": [
            {
              "value": "dimensions",
              "label": "Dimensions"
            },
            {
              "value": "additional_information",
              "label": "Additional Information"
            },
            {
              "value": "delivery_and_returns",
              "label": "Delivery & Returns"
            },
            {
              "value": "care_and_cleaning",
              "label": "Care & Cleaning"
            },
            {
              "value": "description",
              "label": "t:sections.all.select_content.options__1"
            },
            {
              "value": "custom",
              "label": "t:sections.all.select_content.options__2"
            }
          ],
          "default": "custom"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "t:sections.all.content.label"
        },
        {
          "type": "page",
          "id": "page",
          "label": "t:sections.all.content_from_page.label"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "As Seen In",
      "blocks": [
        {
          "type": "as_seen_in"
        }
      ]
    }
  ]
}
{% endschema %}