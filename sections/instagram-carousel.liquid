<script>
  document.addEventListener('DOMContentLoaded', function () {
    const token = '{{ section.settings.instagram_token }}';
    const limit = '{{ section.settings.post_limit }}';
    const feed = document.getElementById('instagram-carousel');

    const instaModal = document.getElementById('instaModal');
    const modalImage = document.getElementById('modal-image');
    const modalCaption = document.getElementById('modal-caption');
    const modalClose = instaModal.querySelector('.btn-close');
    const btnPrev = instaModal.querySelector('.btn-prev');
    const btnNext = instaModal.querySelector('.btn-next');

    let currentIndex = 0;
    let modalPosts = [];

    if (!token) {
      feed.innerHTML = "<li class='splide__slide text-center'>⚠️ Add your Instagram token.</li>";
      return;
    }

    fetch(
      `https://graph.instagram.com/me/media?fields=id,caption,media_url,permalink,media_type&access_token=${token}&limit=${
        limit * 2
      }`
    )
      .then((res) => res.json())
      .then((data) => {
        if (!data.data) {
          feed.innerHTML = "<li class='splide__slide text-center'>⚠️ Could not load feed.</li>";
          return;
        }

        // Filter and limit posts
        const filtered = data.data
          .filter((post) => post.media_type === 'IMAGE' || post.media_type === 'CAROUSEL_ALBUM')
          .slice(0, limit);

        filtered.forEach((post) => {
          const li = document.createElement('li');
          li.className = 'splide__slide insta-wrapper';
          li.innerHTML = `
          <img src="${post.media_url}" alt="Instagram post" 
               class="cursor-pointer"
               data-caption="${post.caption || ''}" data-url="${post.media_url}">
          <div class="insta-overlay">
            <svg 
              class="insta-logo" 
              viewBox="0 0 18 18" 
              aria-hidden="true" 
              focusable="false"
              alt="Instagram"
            >
              <path fill="#fff" d="M8.77 1.58c2.34 0 2.62.01 3.54.05.86.04 1.32.18 1.63.3.41.17.7.35 1.01.66.3.3.5.6.65 1 .12.32.27.78.3 1.64.05.92.06 1.2.06 3.54s-.01 2.62-.05 3.54a4.79 4.79 0 01-.3 1.63c-.17.41-.35.7-.66 1.01-.3.3-.6.5-1.01.66-.31.12-.77.26-1.63.3-.92.04-1.2.05-3.54.05s-2.62 0-3.55-.05a4.79 4.79 0 01-1.62-.3c-.42-.16-.7-.35-1.01-.66-.31-.3-.5-.6-.66-1a4.87 4.87 0 01-.3-1.64c-.04-.92-.05-1.2-.05-3.54s0-2.62.05-3.54c.04-.86.18-1.32.3-1.63.16-.41.35-.7.66-1.01.3-.3.6-.5 1-.65.32-.12.78-.27 1.63-.3.93-.05 1.2-.06 3.55-.06zm0-1.58C6.39 0 6.09.01 5.15.05c-.93.04-1.57.2-2.13.4-.57.23-1.06.54-1.55 1.02C1 1.96.7 2.45.46 3.02c-.22.56-.37 1.2-.4 2.13C0 6.1 0 6.4 0 8.77s.01 2.68.05 3.61c.04.94.2 1.57.4 2.13.23.58.54 1.07 1.02 1.56.49.48.98.78 1.55 1.01.56.22 1.2.37 2.13.4.94.05 1.24.06 3.62.06 2.39 0 2.68-.01 3.62-.05.93-.04 1.57-.2 2.13-.41a4.27 4.27 0 001.55-1.01c.49-.49.79-.98 1.01-1.56.22-.55.37-1.19.41-2.13.04-.93.05-1.23.05-3.61 0-2.39 0-2.68-.05-3.62a6.47 6.47 0 00-.4-2.13 4.27 4.27 0 00-1.02-1.55A4.35 4.35 0 0014.52.46a6.43 6.43 0 00-2.13-.41A69 69 0 008.77 0z">
              </path>
              <path fill="#fff" d="M8.8 4a4.5 4.5 0 100 9 4.5 4.5 0 000-9zm0 7.43a2.92 2.92 0 110-5.85 2.92 2.92 0 010 5.85zM13.43 5a1.05 1.05 0 100-2.1 1.05 1.05 0 000 2.1z">
              </path>
            </svg>
          </div>
        `;
          feed.appendChild(li);

          // Push to modalPosts
          modalPosts.push({
            url: post.media_url,
            caption: post.caption || '',
          });
        });

        // Mount Splide
        const splide = new Splide('#instagram-feed').mount();

        // Attach click events directly to the real slides we created
        feed.querySelectorAll('.insta-wrapper img').forEach((img, index) => {
          img.addEventListener('click', () => {
            currentIndex = index; // this matches modalPosts order exactly
            updateModal();
            instaModal.classList.add('show');
            instaModal.setAttribute('aria-hidden', 'false');
          });
        });

        // Modal navigation
        function updateModal() {
          const post = modalPosts[currentIndex];
          modalImage.src = post.url;
          modalCaption.textContent = post.caption;
        }

        btnPrev.addEventListener('click', () => {
          currentIndex = (currentIndex - 1 + modalPosts.length) % modalPosts.length;
          updateModal();
        });

        btnNext.addEventListener('click', () => {
          currentIndex = (currentIndex + 1) % modalPosts.length;
          updateModal();
        });

        // Close modal
        modalClose.addEventListener('click', () => {
          instaModal.classList.remove('show');
          instaModal.setAttribute('aria-hidden', 'true');
        });

        instaModal.addEventListener('click', (e) => {
          if (e.target === instaModal) {
            instaModal.classList.remove('show');
            instaModal.setAttribute('aria-hidden', 'true');
          }
        });
      });
  });
</script>

<style>
  /* Grid & Utilities */
  .container {
    max-width: 1920px;
    margin: 0 auto;
    padding: 0 15px;
  }
  .row {
    display: flex;
    flex-wrap: wrap;
    margin-left: -0.75rem;
    margin-right: -0.75rem;
  }
  .g-3 > * {
    padding: 0.75rem;
  }
  .col-6 {
    flex: 0 0 50%;
    max-width: 50%;
  }

  @media (min-width: 576px) {
    .col-sm-6 {
      flex: 0 0 50%;
      max-width: 50%;
    }
  }

  @media (min-width: 768px) {
    .col-md-4 {
      flex: 0 0 33.333%;
      max-width: 33.333%;
    }
    .col-md-5th {
      flex: 0 0 20%;
      max-width: 20%;
    }
    .d-md-flex {
      display: flex !important;
    }
    .d-md-block {
      display: block !important;
    }
    .d-md-none {
      display: none !important;
    }
  }
  .insta-wrapper .d-none {
