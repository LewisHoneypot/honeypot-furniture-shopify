{% stylesheet %}
  .page-product {
    .color-list {
      display: grid;
      max-width: 400px;
      max-height: 70px;
    }
    .color-list a {
      margin-right: 1rem;
    }
    .color-item {
      aspect-ratio: 1;
      display: block !important;
      @media screen and (min-width: 990px) {
        max-width: none;
        max-height: none;
      }
    }
    .drawer__wrapper {
      margin-top: 30px;
      .drawer__wrapper-details {
        a,
        a:hover,
        a:visited {
          text-decoration: none;
          color: rgba(var(--color-foreground), 1);
        }
        .recommended-product {
          display: flex;
          min-height: 100px;
          .img-container {
            min-width: 100px;
            display: flex;
            justify-content: center;
            img {
              object-fit: contain;
              width: 100px;
              height: 100px;
            }
          }
          .info {
            margin: auto 0 auto 21px;
            .price {
              margin: auto;
            }
            .title {
              margin: 0;
            }
          }
        }
      }
    }
  }

  #reviews {
    video {
      max-width: 100%;
    }
    .userIcon {
      min-width: 26px;
    }
    .innerDiv {
      border-bottom: solid 1px #f2f2f2;
      .review-wrapper {
        .customerInfo {
          width: -webkit-fill-available;
        }
        .attributeNames,
        .attributeStars {
          float: left;
          @media screen and (min-width: 768px) {
            margin: 44px 0;
          }
        }
      }
    }
  }
  .ammount-of-reviews {
    position: relative;
    left: 5px;
    color: rgba(var(--color-foreground), 1);
  }

  #reviews-button {
    text-decoration: none;
    cursor: pointer;
    min-height: 25px;
  }

  .tp-widget-readmore-arrow {
    border-bottom: solid 1px #191919;
    border-left: solid 1px #191919;
    bottom: 3px;
    height: 5px;
    left: 9px;
    position: relative;
    transform: rotate(-45deg);
    width: 5px;
    transition: transform 0.2s;
    display: inline-block;
    cursor: pointer;
    opacity: 0.6;
  }
{% endstylesheet %}

<script>
  var productSku = "{{ product.variants[0].sku }}";

  {%- if trustpilot_skus %}
    var trustpilot_skus = {{ trustpilot_skus }};
  {%- endif -%}

  // shop pay button test
  document.addEventListener('DOMContentLoaded', function() {
    function attachClickListener() {
      var shopifyPayButton = document.querySelector('[data-testid="ShopifyPay-button"]');
      if (shopifyPayButton) {
        shopifyPayButton.addEventListener('click', function() {
          gtag('event', 'shopify_pay_pdp_click', {
            event_category: 'engagement',
            event_label: 'ShopifyPay Button PDP',
            value: 1
          });
        });
        observer.disconnect();
      }
    }

    var observer = new MutationObserver(attachClickListener);

    observer.observe(document.body, {
      childList: true,
      subtree: true
    });

    attachClickListener();
  });
</script>
